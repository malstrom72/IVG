{
	"name": "ivgfiddle-vscode",
	"displayName": "IVGFiddle",
	"description": "Embed IVGFiddle as a webview inside Visual Studio Code.",
	"version": "0.0.1",
	"publisher": "ivg",
	"engines": {
		"vscode": "^1.84.0"
	},
        "activationEvents": [
                "onCommand:ivgfiddle.open",
                "onCommand:ivgfiddle.refreshPreview",
                "onCommand:ivgfiddle.clearTrace",
                "onLanguage:ivg"
        ],
        "main": "./dist/extension.js",
        "contributes": {
                "commands": [
                        {
                                "command": "ivgfiddle.open",
                                "title": "Open IVGFiddle",
                                "category": "IVGFiddle"
                        },
                        {
                                "command": "ivgfiddle.refreshPreview",
                                "title": "Refresh IVGFiddle Preview",
                                "category": "IVGFiddle"
                        },
                        {
                                "command": "ivgfiddle.clearTrace",
                                "title": "Clear IVGFiddle Preview Trace",
                                "category": "IVGFiddle"
                        }
                ],
                "languages": [
                        {
                                "id": "ivg",
                                "aliases": [
                                        "IVG",
                                        "ivg"
                                ],
                                "extensions": [
                                        ".ivg"
                                ],
                                "configuration": "./language-configuration.json"
                        }
                ],
                "configuration": {
                        "title": "IVGFiddle Preview",
                        "properties": {
                                "ivgfiddle.preview.autoRefresh": {
                                        "type": "boolean",
                                        "default": true,
                                        "description": "Automatically update the IVGFiddle preview when IVG documents change."
                                },
                                "ivgfiddle.preview.debounceMs": {
                                        "type": "number",
                                        "default": 150,
                                        "minimum": 0,
                                        "description": "Delay in milliseconds before automatic preview refresh when auto refresh is enabled."
                                }
                        }
                }
        },
	"scripts": {
		"compile": "tsc -p .",
		"watch": "tsc -w -p ."
	},
	"devDependencies": {
		"@types/vscode": "^1.84.0",
		"typescript": "^5.6.3"
	}
}
